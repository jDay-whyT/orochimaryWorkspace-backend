# Telegram
TELEGRAM_BOT_TOKEN=${{ secrets.TELEGRAM_BOT_TOKEN }}
TELEGRAM_WEBHOOK_SECRET=${{ secrets.TELEGRAM_WEBHOOK_SECRET }}

# Notion
NOTION_TOKEN=${{ secrets.NOTION_TOKEN }}

# Database IDs (data source / collection IDs)
DB_MODELS=${{ secrets.NOTION_MODELS_DB_ID }}
DB_ORDERS=${{ secrets.NOTION_ORDERS_DB_ID }}
DB_PLANNER=${{ secrets.DB_PLANNER }}
DB_ACCOUNTING=${{ secrets.DB_ACCOUNTING }}
DB_FORMS=                        # optional; defaults to DB_FORMS_DEFAULT in app/utils/constants.py

# Access control
ALLOWED_EDITORS=${{ vars.ALLOWED_EDITORS }}   # comma-separated Telegram user IDs
CRM_TOPIC_THREAD_ID=${{ vars.CRM_TOPIC_THREAD_ID }}

# Access control (optional)
REPORT_VIEWERS=                # comma-separated Telegram user IDs
SCOUTS_CHAT_ID=                # Telegram chat ID for scout notifications

# Settings
TIMEZONE=${{ vars.TIMEZONE }}
FILES_PER_MONTH=${{ vars.FILES_PER_MONTH }}

# Optional infrastructure
REDIS_URL=                     # optional; falls back to in-memory state if not set

# Internal
INTERNAL_SECRET=               # optional internal webhook secret
MANAGERS_CHAT_ID=              # optional
MANAGERS_TOPIC_THREAD_ID=      # optional
RENT_TOPIC_THREAD_ID=          # optional
BOARD_MESSAGE_ID=              # optional

# Integrations
APIFY_TOKEN=${{ secrets.APIFY_TOKEN }}
OMKAR_TOKEN=${{ secrets.OMKAR_TOKEN }}

# Runtime (Cloud Run / container)
PORT=8080                      # optional; used by app/server.py
GIT_SHA=unknown                # optional; used for diagnostics
